# Environment variables for DocuSense API
# Copy this file to .env and modify as needed

# Application settings
APP_NAME=DocuSense API
APP_VERSION=0.1.0
APP_DESCRIPTION=A FastAPI REST API application for document management
DEBUG=false

# Server settings
HOST=0.0.0.0
PORT=8000

# API settings
API_PREFIX=/api/v1

# Database settings
# For local development with Docker:
DATABASE_URL=postgresql+asyncpg://docusense:docusense@localhost:5432/docusense
# For Docker Compose (api service):
# DATABASE_URL=postgresql+asyncpg://docusense:docusense@db:5432/docusense

# File storage settings
UPLOAD_DIR=uploads
MAX_FILE_SIZE=52428800  # 50MB in bytes
# Allowed extensions (comma-separated, include the dot)
# Now includes image formats for OCR
ALLOWED_EXTENSIONS=.pdf,.txt,.md,.doc,.docx,.png,.jpg,.jpeg,.tiff,.bmp

# Embedding settings
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# OCR settings
OCR_USE_GPU=false
# OCR_LANGUAGES=en  # Comma-separated list of language codes

# QA Model settings
QA_MODEL_NAME=distilbert/distilbert-base-cased-distilled-squad
QA_MAX_CONTEXT_LENGTH=512
QA_TOP_K_CHUNKS=5

# Rate limiting settings
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=30

# Caching settings
CACHE_TTL_SECONDS=3600  # 1 hour
CACHE_MAX_SIZE=1000
